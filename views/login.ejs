<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login - Meu Gasto</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#0f0f0f;color:#e0e0e0;display:flex;justify-content:center;align-items:center;min-height:100vh;padding:20px}
.box{background:#1a1a1a;padding:32px;border-radius:16px;width:100%;max-width:360px;text-align:center}
h1{font-size:28px;margin-bottom:4px}
.sub{color:#666;font-size:14px;margin-bottom:24px}
input{width:100%;padding:14px;margin-bottom:12px;border-radius:8px;border:1px solid #333;background:#0f0f0f;color:#e0e0e0;font-size:15px}
input:focus{outline:none;border-color:#4ade80}
button{width:100%;padding:14px;border-radius:8px;border:none;background:#22c55e;color:#000;font-weight:700;font-size:15px;cursor:pointer;transition:.2s}
button:active{transform:scale(.97)}
.error{color:#f87171;font-size:13px;margin-bottom:12px;padding:8px;background:#7f1d1d33;border-radius:6px}
</style>
</head>
<body>
<div class="box">
  <h1>💰</h1>
  <h1>Meu Gasto</h1>
  <p class="sub">Controle seus gastos mensais</p>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form method="POST">
    <input type="text" name="username" placeholder="Usuário" required>
    <input type="password" name="password" placeholder="Senha" required>
    <button type="submit">Entrar</button>
  </form>
</div>
</body>
</html>